{
  "name": "property-search",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --filter @property-search/web dev & pnpm --filter @property-search/api dev",
    "dev:web": "pnpm --filter @property-search/web dev",
    "dev:api": "pnpm --filter @property-search/api dev",
    "build": "pnpm --filter @property-search/api build && pnpm --filter @property-search/web build",
    "build:web": "pnpm --filter @property-search/web build",
    "build:api": "pnpm --filter @property-search/api build",
    "start": "pnpm --filter @property-search/web start & pnpm --filter @property-search/api start:prod",
    "start:web": "pnpm --filter @property-search/web start",
    "start:api": "pnpm --filter @property-search/api start:prod",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "typescript": "^5"
  }
}
